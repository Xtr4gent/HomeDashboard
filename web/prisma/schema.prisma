// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ScenarioStatus {
  draft
  applied
}

enum ScenarioItemType {
  recurring
  financed
  one_time
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Bill {
  id             String    @id @default(cuid())
  name           String
  category       String
  amountCents    Int
  recurrenceRule String
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
}

model Payment {
  id              String   @id @default(cuid())
  billId          String
  amountCents     Int
  paidAt          DateTime
  paymentEventKey String   @unique
  createdAt       DateTime @default(now())
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, paidAt])
}

model Upgrade {
  id         String   @id @default(cuid())
  title      String
  costCents  Int
  loggedAt   DateTime
  category   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([loggedAt, category])
}

model Scenario {
  id                      String         @id @default(cuid())
  name                    String
  notes                   String?
  status                  ScenarioStatus @default(draft)
  version                 Int            @default(1)
  monthlyTotalCents       Int            @default(0)
  yearlyTotalCents        Int            @default(0)
  financedMonthlyCents    Int            @default(0)
  recurringMonthlyCents   Int            @default(0)
  oneTimeCents            Int            @default(0)
  appliedAt               DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  items                   ScenarioItem[]

  @@index([status, updatedAt])
}

model ScenarioItem {
  id               String           @id @default(cuid())
  scenarioId       String
  label            String
  category         String
  itemType         ScenarioItemType
  amountCents      Int
  recurrenceRule   String?
  termMonths       Int?
  annualRateBps    Int?
  sourceKind       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  scenario         Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId, itemType])
}
