// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ScenarioStatus {
  draft
  applied
}

enum ScenarioItemType {
  recurring
  financed
  one_time
}

enum AnalyticsJobStatus {
  queued
  processing
  completed
  failed
}

enum UpgradeProjectStatus {
  planned
  in_progress
  completed
  archived
}

enum MonthCloseStatus {
  locked
  reopened
}

enum ActivityAction {
  bill_added
  bill_paid
  upgrade_added
  projection_saved
  projection_deleted
  upgrade_project_saved
  upgrade_project_deleted
  scenario_saved
  scenario_applied
  home_profile_saved
  month_closed
  month_reopened
  budget_imported
  budget_target_saved
  budget_transaction_updated
  budget_ai_suggestion_reviewed
}

enum BudgetImportStatus {
  queued
  completed
  failed
}

enum BudgetAiSuggestionStatus {
  pending
  applied
  dismissed
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Bill {
  id             String    @id @default(cuid())
  name           String
  category       String
  amountCents    Int
  recurrenceRule String
  sourceScenarioItemId String? @unique
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
}

model Payment {
  id              String   @id @default(cuid())
  billId          String
  amountCents     Int
  paidAt          DateTime
  paymentEventKey String   @unique
  createdAt       DateTime @default(now())
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId, paidAt])
}

model Upgrade {
  id         String   @id @default(cuid())
  title      String
  costCents  Int
  loggedAt   DateTime
  category   String
  sourceScenarioItemId String? @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([loggedAt, category])
}

model Scenario {
  id                      String         @id @default(cuid())
  name                    String
  notes                   String?
  status                  ScenarioStatus @default(draft)
  version                 Int            @default(1)
  monthlyTotalCents       Int            @default(0)
  yearlyTotalCents        Int            @default(0)
  financedMonthlyCents    Int            @default(0)
  recurringMonthlyCents   Int            @default(0)
  oneTimeCents            Int            @default(0)
  appliedAt               DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  items                   ScenarioItem[]

  @@index([status, updatedAt])
}

model ScenarioItem {
  id               String           @id @default(cuid())
  scenarioId       String
  label            String
  category         String
  itemType         ScenarioItemType
  amountCents      Int
  recurrenceRule   String?
  termMonths       Int?
  annualRateBps    Int?
  sourceKind       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  scenario         Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId, itemType])
}

model HomeProfileSnapshot {
  id                         String   @id @default(cuid())
  monthKey                   String   @unique
  propertyAddress            String
  semiMonthlyPaymentCents    Int
  mortgageInterestRatePct    Decimal  @db.Decimal(5, 3)
  mortgageTermYears          Int      @default(5)
  mortgageTermStartMonthKey  String
  mortgageTermEndMonthKey    String
  mortgageLender             String?
  mortgageNotes              String?
  propertyTaxYearlyCents     Int
  waterMonthlyCents          Int
  gasMonthlyCents            Int
  hydroMonthlyCents          Int
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([monthKey, updatedAt])
}

model AnalyticsSnapshotDaily {
  id                        String   @id @default(cuid())
  dayKey                    String   @unique
  monthKey                  String
  totalMonthlyCostCents     Int
  projectedYearlyCostCents  Int
  utilitiesTotalCents       Int
  upgradesTotalCents        Int
  utilityProjectionPlannedCents Int   @default(0)
  utilityProjectionActualCents Int    @default(0)
  utilityProjectionVarianceCents Int  @default(0)
  utilityProjectionCoverageCount Int  @default(0)
  upgradeProjectionPlannedCents Int   @default(0)
  upgradeProjectionActualCents Int    @default(0)
  upgradeProjectionVarianceCents Int  @default(0)
  upgradeProjectionCoverageCount Int  @default(0)
  paidRatePct               Int
  topCategory               String?
  topCategoryTotalCents     Int?
  sourceEventKey            String
  generatedAt               DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([monthKey, generatedAt])
}

model AnalyticsSnapshotMonthly {
  id                        String   @id @default(cuid())
  monthKey                  String   @unique
  totalMonthlyCostCents     Int
  projectedYearlyCostCents  Int
  utilitiesTotalCents       Int
  upgradesTotalCents        Int
  utilityProjectionPlannedCents Int   @default(0)
  utilityProjectionActualCents Int    @default(0)
  utilityProjectionVarianceCents Int  @default(0)
  utilityProjectionCoverageCount Int  @default(0)
  upgradeProjectionPlannedCents Int   @default(0)
  upgradeProjectionActualCents Int    @default(0)
  upgradeProjectionVarianceCents Int  @default(0)
  upgradeProjectionCoverageCount Int  @default(0)
  paidRatePct               Int
  topCategory               String?
  topCategoryTotalCents     Int?
  sourceEventKey            String
  generatedAt               DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([generatedAt])
}

model AnalyticsRecomputeJob {
  id             String             @id @default(cuid())
  sourceEventKey String             @unique
  triggerType    String
  status         AnalyticsJobStatus @default(queued)
  attempts       Int                @default(0)
  queuedAt       DateTime           @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  errorMessage   String?
  updatedAt      DateTime           @updatedAt

  @@index([status, queuedAt])
}

model UtilityProjection {
  id           String   @id @default(cuid())
  monthKey     String
  category     String
  plannedCents Int
  actualCents  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([monthKey, category])
  @@index([monthKey, updatedAt])
}

model UpgradeProject {
  id               String             @id @default(cuid())
  title            String
  category         String
  notes            String?
  status           UpgradeProjectStatus @default(planned)
  startMonthKey    String
  targetMonthKey   String
  plannedTotalCents Int               @default(0)
  actualTotalCents Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  planMonths       UpgradePlanMonth[]
  actualMonths     UpgradeActualMonth[]

  @@index([status, targetMonthKey])
}

model UpgradePlanMonth {
  id          String        @id @default(cuid())
  projectId   String
  monthKey    String
  plannedCents Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     UpgradeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, monthKey])
  @@index([monthKey, updatedAt])
}

model UpgradeActualMonth {
  id          String        @id @default(cuid())
  projectId   String
  monthKey    String
  actualCents Int
  loggedAt    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     UpgradeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, monthKey])
  @@index([monthKey, loggedAt])
}

model MonthClose {
  id                          String           @id @default(cuid())
  monthKey                    String           @unique
  status                      MonthCloseStatus @default(locked)
  totalMonthlyCostCents       Int
  cashflowThisMonthCostCents  Int
  projectedYearlyCostCents    Int
  utilitiesTotalCents         Int
  upgradesTotalCents          Int
  utilityProjectionVarianceCents Int          @default(0)
  upgradeProjectionVarianceCents Int          @default(0)
  closedByUsername            String
  closedAt                    DateTime         @default(now())
  reopenedAt                  DateTime?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt

  @@index([closedAt])
}

model ActivityLog {
  id             String         @id @default(cuid())
  action         ActivityAction
  actorUsername  String
  monthKey       String?
  entityType     String
  entityId       String?
  summary        String
  metadata       Json?
  createdAt      DateTime       @default(now())

  @@index([createdAt])
  @@index([monthKey, createdAt])
}

model BudgetAccount {
  id           String            @id @default(cuid())
  name         String
  institution  String            @default("")
  currencyCode String            @default("CAD")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  imports      BudgetImportBatch[]
  transactions BudgetTransaction[]

  @@unique([name, institution])
}

model BudgetImportBatch {
  id             String           @id @default(cuid())
  accountId      String
  monthKey       String
  status         BudgetImportStatus @default(queued)
  rowCount       Int              @default(0)
  cleanedRowCount Int             @default(0)
  importedCount  Int              @default(0)
  duplicateCount Int              @default(0)
  aiNormalizationUsed Boolean     @default(false)
  aiNormalizationCostCents Int    @default(0)
  cleanedRowsJson Json?
  errorMessage   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  account        BudgetAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions   BudgetTransaction[]

  @@index([monthKey, createdAt])
}

model BudgetTransaction {
  id               String           @id @default(cuid())
  accountId        String
  importBatchId    String?
  postedAt         DateTime
  monthKey         String
  description      String
  normalizedMerchant String
  amountCents      Int
  category         String
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  account          BudgetAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  importBatch      BudgetImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  aiSuggestion     BudgetAiSuggestion?

  @@index([monthKey, postedAt])
  @@index([normalizedMerchant, postedAt])
}

model BudgetAiSuggestion {
  id                 String                  @id @default(cuid())
  transactionId      String                  @unique
  monthKey           String
  suggestedMerchant  String
  suggestedCategory  String
  confidence         Decimal                 @db.Decimal(5, 4)
  reason             String
  status             BudgetAiSuggestionStatus @default(pending)
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  transaction        BudgetTransaction       @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([monthKey, status, createdAt])
}

model BudgetCategoryRule {
  id         String   @id @default(cuid())
  matchText  String
  category   String
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([matchText, category])
  @@index([priority])
}

model BudgetMonthlyTarget {
  id         String   @id @default(cuid())
  monthKey   String
  category   String
  targetCents Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([monthKey, category])
  @@index([monthKey, category])
}

model BudgetTxnMatch {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
